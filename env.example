# =============================================================================
# Django Core Settings
# =============================================================================
SECRET_KEY=your-secret-key-here-change-this-in-production-use-django-insecure-for-dev-only
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1
# Site URL for sitemap and robots.txt (optional - auto-detected from ALLOWED_HOSTS if not set)
# SITE_URL=https://yourdomain.com

# =============================================================================
# Database Settings (PostgreSQL)
# =============================================================================
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your-strong-database-password-here
DB_HOST=db
DB_PORT=5432

# Docker PostgreSQL container settings (if using docker-compose)
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your-strong-database-password-here

# Docker Compose dev (`docker-compose.yml` web): use your workstation uid/gid so
# tools inside the container can write migrations and code on mounted volumes.
# Run: id -u   and   id -g
# HOST_UID=1000
# HOST_GID=1000
#
# Production (`docker-compose.prod.yml`): Doppler writes `secrets.env` on the VPS.
# Do not use a project-root `.env` in production — Compose interpolates `$` in it.
#
# Optional: redirect file logs (default: <project>/logs). Dev compose sets
# SHIFTED_BLOG_LOG_DIR=/tmp/shiftedblog_logs so logging works with HOST_UID.
# SHIFTED_BLOG_LOG_DIR=/tmp/shiftedblog_logs

# Back ups
BACKUP_DIR="/backups"
YANDISK_TOKEN=your-token-here

# =============================================================================
# Session Security Settings
# =============================================================================
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_AGE=3600
SESSION_EXPIRE_AT_BROWSER_CLOSE=False

# =============================================================================
# SSL/TLS Security Settings
# =============================================================================
SECURE_SSL_REDIRECT=True
# 31536000 = 1 year (production). Use 0 to disable HSTS (development only).
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# =============================================================================
# CSRF Protection Settings
# =============================================================================
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_HTTPONLY=False
# IMPORTANT: In production, only HTTPS URLs are allowed. HTTP URLs will cause startup error.
# Development mode allows HTTP for localhost only.
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# Security Headers
# =============================================================================
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True

# Content-Security-Policy: configured in settings via SECURE_CSP (Django 6 built-in).
# Edit SECURE_CSP in shiftedblog/settings.py to change allowed sources.

# Permissions-Policy (optional - uses default if not set)
# Default restricts most browser features for privacy
# PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=(), ...

# =============================================================================
# Brute Force Protection (django-axes)
# =============================================================================
AXES_ENABLED=True
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1
AXES_RESET_ON_SUCCESS=True
AXES_VERBOSE=True
AXES_LOGIN_FAILURE_LIMIT=5
# Note: AXES_ONLY_USER_FAILURES is deprecated, use AXES_LOCKOUT_PARAMETERS instead
# Behind nginx reverse proxy (one hop):
AXES_IPWARE_PROXY_COUNT=1
AXES_IPWARE_PROXY_ORDER=left-most

# =============================================================================
# Application-Level Rate Limiting (django-ratelimit)
# =============================================================================
# Enable django-ratelimit (works alongside nginx rate limiting for defense in depth)
RATELIMIT_ENABLE=True

# =============================================================================
# Redis Cache Configuration
# =============================================================================
# Redis URL for cache backend (required for django-ratelimit)
# Default: redis://redis:6379/1 (for Docker Compose)
# For local development: redis://localhost:6379/1
REDIS_URL=redis://redis:6379/1

# =============================================================================
# Admin Settings
# =============================================================================
# Admin URL path (security through obscurity - change from default 'mellon')
# Generate: openssl rand -hex 8  (see scripts/security/generate-admin-url.sh)
ADMIN_URL=mellon
# ADMIN_NAME=Admin
ADMIN_EMAIL=admin@yourdomain.com

# =============================================================================
# Email (lockout alerts, security reports)
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
# Beget (smtp.beget.com): port 465, EMAIL_USE_SSL=True, EMAIL_USE_TLS=False
# DEFAULT_FROM_EMAIL and EMAIL_HOST_USER must be the same Beget mailbox address.
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# Secrets rotation reminders (optional ISO dates YYYY-MM-DD)
# =============================================================================
# SECRET_KEY_ROTATED_AT=2026-01-15
# CREDENTIALS_ENCRYPTION_KEY_ROTATED_AT=2026-01-15
SECRETS_ROTATION_MAX_AGE_DAYS=90

# =============================================================================
# Third-party Services
# =============================================================================
# Dzen verification file (optional)
DZEN_VERIFICATION_FILE=

# Optional local Python checker for text quality checks in admin.
# Uses optional python libs in environment:
#   pip install language-tool-python pyspellchecker
TEXT_QUALITY_PY_CHECKER_ENABLED=False
# Language code for local language_tool_python checker.
TEXT_QUALITY_LANGUAGETOOL_LANGUAGE=ru-RU

# =============================================================================
# Multi-channel publishing (sender) – optional
# =============================================================================
# Fernet key for encrypting rows in core.Credential (generate once per environment):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=
# Optional Telegram bootstrap if DB credentials are not configured:
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_NAME=mychannel
# TELEGRAM_CHAT_ID=
# TELEGRAM_CHANNEL_HAS_SUBSCRIPTION=false
# (Use TELEGRAM_CHANNEL_NAME for public @username channels; TELEGRAM_CHAT_ID for numeric chat ids.)
# Layout auto-detect: bot calls getChatAdministrators and uses owner user.is_premium.
# Override in credential JSON: "channel_subscription": true|false, or "auto".
# TELEGRAM_CHANNEL_HAS_SUBSCRIPTION is only used when auto-detect fails.
# If Telegram returns "bot is not a member of the channel", add the bot as a channel admin
# with "Post messages"; private channels usually need TELEGRAM_CHAT_ID (numeric).
# Optional HTTP(S) proxy for Telegram Bot API client:
# HTTP_PROXY=
# HTTPS_PROXY=
# TELEGRAM_HTTP_PROXY=
# Telegram Stories (optional MTProto operator session — channel admin user, not the bot):
# Omit these to disable stories; Bot API posting still works with TELEGRAM_BOT_TOKEN only.
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_OPERATOR_SESSION=
# Prefer storing api_id, api_hash, operator_session in core.Credential JSON.
# Upload story fallback image on Core → Networks → Telegram when posts may have no images.
# Authorize operator session once:
#   python manage.py telegram_operator_login --phone +79001234567

# =============================================================================
# Editor SPA (subdomain)
# =============================================================================
# EDITOR_URL=https://editor.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://editor.yourdomain.com
# SESSION_COOKIE_DOMAIN=.yourdomain.com
# CSRF_COOKIE_DOMAIN=.yourdomain.com
# SESSION_COOKIE_SAMESITE=None
# CSRF_COOKIE_SAMESITE=None

# =============================================================================
# Other Settings
# =============================================================================
PREPEND_WWW=False
